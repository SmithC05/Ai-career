# Global
PROJECT_NAME=ai-career-navigator

# Postgres
POSTGRES_DB=career_nav
POSTGRES_USER=career_user
POSTGRES_PASSWORD=career_pass
POSTGRES_PORT=5432

# Backend
BACKEND_PORT=8080
JWT_SECRET=replace-with-a-long-random-secret
JWT_EXPIRATION_MS=86400000
FRONTEND_BASE_URL=http://localhost:3000

# Frontend
FRONTEND_PORT=3000
# Local Development
NEXT_PUBLIC_API_BASE_URL=http://localhost:8080/api/v1
# Vercel Production Format (replace with your Render backend URL)
# NEXT_PUBLIC_API_BASE_URL=https://acn-backend-YOUR_IDENTIFIER.onrender.com/api/v1

# AI Service
AI_SERVICE_PORT=8000
OLLAMA_BASE_URL=http://ollama:11434
OLLAMA_MODEL_ADVISOR=qwen2.5:0.5b
OLLAMA_MODEL_ROADMAP=qwen2.5:0.5b
OLLAMA_MODEL_LIGHT=qwen2.5:0.5b
OLLAMA_TIMEOUT_SECONDS=12
OLLAMA_REQUEST_DEADLINE_SECONDS=8
OLLAMA_NUM_CTX=2048
OLLAMA_KEEP_ALIVE=30m

# Ollama
OLLAMA_PORT=11434
